{
  "name": "pi-local-rag",
  "version": "0.3.0",
  "description": "Hybrid RAG pipeline for the Pi coding agent. BM25 + local vector embeddings (Transformers.js) + auto-injection into LLM context. Zero cloud dependency.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json --noCheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "rag",
    "search",
    "bm25",
    "vector",
    "embeddings",
    "hybrid-search",
    "index",
    "local",
    "offline",
    "transformers"
  ],
  "author": "kowsari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vahidkowsari/pi-local-rag.git"
  },
  "homepage": "https://github.com/vahidkowsari/pi-local-rag#readme",
  "bugs": {
    "url": "https://github.com/vahidkowsari/pi-local-rag/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ignore": "^7.0.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.60.0",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "jszip": "^3.10.1",
    "vitest": "^4.1.4"
  }
}
